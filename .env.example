# Firebase configuration (client-side — NOT secrets, but kept in .env for clean config management)
# Create a free Firebase project at https://console.firebase.google.com
# Note: Firebase client config is safe to expose per Firebase docs — real security
# is enforced by Firestore Security Rules, not by hiding the config.
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
