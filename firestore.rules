rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isValidCategory(category) {
      return category in ['transport', 'energy', 'food', 'waste'];
    }

    function isValidMode(category, mode) {
      return (category == 'transport' &&
                mode in ['car_petrol', 'car_diesel', 'car_electric', 'bus', 'train',
                         'flight_short', 'flight_long', 'bicycle', 'walk']) ||
             (category == 'energy' && mode in ['electricity', 'natural_gas']) ||
             (category == 'food' && mode in ['meat_heavy', 'meat_light', 'vegetarian', 'vegan']) ||
             (category == 'waste' && mode in ['landfill', 'recycled', 'composted']);
    }

    function isValidUnit(category, unit) {
      return (category == 'transport' && unit == 'km') ||
             (category == 'energy' && unit == 'kWh') ||
             (category == 'food' && unit == 'meals') ||
             (category == 'waste' && unit == 'kg');
    }

    function isValidEntryData(data, userId) {
      return data.keys().hasAll(['category', 'mode', 'value', 'unit', 'date', 'userId']) &&
             data.keys().hasOnly(['category', 'mode', 'value', 'unit', 'date', 'userId', 'createdAt']) &&
             data.userId == userId &&
             data.category is string &&
             isValidCategory(data.category) &&
             data.mode is string &&
             isValidMode(data.category, data.mode) &&
             data.unit is string &&
             isValidUnit(data.category, data.unit) &&
             data.date is string &&
             data.value is number &&
             data.value >= 0 &&
             data.value < 100000;
    }

    // User profile documents: only the owner can read/write their own profile.
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Carbon footprint log entries: auth-scoped with shared create/update validation.
    match /users/{userId}/entries/{entryId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId) &&
                    isValidEntryData(request.resource.data, userId);

      allow update: if isOwner(userId) &&
                    isValidEntryData(request.resource.data, userId) &&
                    request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isOwner(userId);
    }

    // Default: deny all other paths.
  }
}
